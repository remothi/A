    local function updateButtonSizeAndPosition()
        local screenSize = workspace.CurrentCamera.ViewportSize
        Button.Size = UDim2.new(0, screenSize.X * 0.1, 0, screenSize.X * 0.1)
        Button.Position = UDim2.new(0.85, 0, 0.65, 0)
    end

    updateButtonSizeAndPosition()
    workspace.CurrentCamera:GetPropertyChangedSignal("ViewportSize"):Connect(updateButtonSizeAndPosition)

    local currentPrompt = nil
    local holding = false

    local function setupPrompt(prompt)
        prompt.PromptShown:Connect(function()
            currentPrompt = prompt
            Button.Visible = true
        end)
        prompt.PromptHidden:Connect(function()
            if currentPrompt == prompt then
                currentPrompt = nil
                Button.Visible = false
            end
        end)
    end

    for _, prompt in pairs(Workspace:GetDescendants()) do
        if prompt:IsA("ProximityPrompt") then
            setupPrompt(prompt)
        end
    end

    Workspace.DescendantAdded:Connect(function(desc)
        if desc:IsA("ProximityPrompt") then
            setupPrompt(desc)
        end
    end)

    Button.MouseButton1Down:Connect(function()
        if currentPrompt then
            holding = true
            currentPrompt:InputHoldBegin()
        end
    end)

    Button.MouseButton1Up:Connect(function()
        if currentPrompt and holding then
            holding = false
            currentPrompt:InputHoldEnd()
        end
    end)
end

