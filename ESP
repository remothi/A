end

local function getAgentParams()
	local costs = { GatePivot1 = 1, GatePivot2 = 1 }
	for _, obj in ipairs(safeAreaFolder:GetDescendants()) do
		if obj:IsA("BasePart") then costs[obj.Name] = math.huge end
	end
	return { AgentRadius = 2, AgentHeight = 5, AgentCanJump = true, Costs = costs }
end

local function getTarget()
	local closest = nil
	local minDist = math.huge
	for _, p in ipairs(Players:GetPlayers()) do
		if p ~= player and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
			if isTargetable(p) then
