RunService.RenderStepped:Connect(function()
    local char = player.Character
    local hum = char and char:FindFirstChildOfClass("Humanoid")
    local head = char and char:FindFirstChild("Head")
    local camera = workspace.CurrentCamera

    if char and hum then
        if State.speedEnabled then hum.WalkSpeed = State.walkSpeed end
        if State.jumpPowerEnabled then hum.JumpPower = State.jumpPower else hum.JumpPower = 50 end
    end

    local clientFolder = workspace:FindFirstChild("Client")
    if clientFolder then
        local viewModel = clientFolder:FindFirstChild("characterViewModel")
        if State.bypassEnabled then
            if viewModel then viewModel.Parent = vmStorage end
        else
            local hiddenVM = vmStorage:FindFirstChild("characterViewModel")
            if hiddenVM then hiddenVM.Parent = clientFolder end
        end
    end

    if State.bypassEnabled and camera then
        if player:GetAttribute("inCutScene") == true or camera.CameraType == Enum.CameraType.Scriptable then
            if tick() - State.lastReset > 0.5 then
                State.lastReset = tick()
                local oldFOV, oldCFrame = camera.FieldOfView, camera.CFrame
                camera:Destroy()
                local newCamera = Instance.new("Camera")
                newCamera.Parent = workspace
                newCamera.FieldOfView = oldFOV
                newCamera.CFrame = oldCFrame
                newCamera.CameraType = Enum.CameraType.Custom
                newCamera.CameraSubject = hum
                workspace.CurrentCamera = newCamera
            end
        end
        player:SetAttribute("inCutScene", false)
        player:SetAttribute("isMoveable", true)
        
        if head then
            local distance = (camera.CFrame.Position - head.Position).Magnitude
            local isFirstPerson = distance < 2.5
            for _, part in pairs(char:GetDescendants()) do
                if (part:IsA("BasePart") or part:IsA("Decal")) and part.Name ~= "HumanoidRootPart" then
                    if not State.isBodyVisible or isFirstPerson then
                        part.LocalTransparencyModifier = 1
                    else
                        part.LocalTransparencyModifier = 0
                    end
                end
            end
        end
    end
end)

