local noclipEnabled = false
local connection
local originalCollide = {}

local function applyNoclip()
	if connection then connection:Disconnect() end
	connection = RunService.Stepped:Connect(function()
		if player.Character then
			for _, part in ipairs(player.Character:GetDescendants()) do
				if part:IsA("BasePart") then
					part.CanCollide = false
				end
			end

			local hrp = player.Character:FindFirstChild("HumanoidRootPart")
			if hrp then
				local pos = hrp.Position
				if pos.Y < 0 then
					local ori = hrp.Orientation
					hrp.CFrame = CFrame.new(Vector3.new(pos.X, 3, pos.Z)) * CFrame.Angles(
						math.rad(ori.X),
						math.rad(ori.Y),
						math.rad(ori.Z)
					)
				end
			end
		end
	end)
end

local function disableNoclip()
	if connection then connection:Disconnect() end
	if player.Character then
		for part, state in pairs(originalCollide) do
			if part and part:IsA("BasePart") then
				part.CanCollide = state
			end
		end
	end
end

local function setNoclip(state)
	noclipEnabled = state
	if state then
		Button.Text = "ON"
		Button.BackgroundColor3 = Color3.fromRGB(50,180,80)
		applyNoclip()
	else
		Button.Text = "OFF"
		Button.BackgroundColor3 = Color3.fromRGB(180,50,50)
		disableNoclip()
	end
end

player.CharacterAdded:Connect(function(char)
	task.wait(0.5)
	originalCollide = {}
	for _, part in ipairs(char:GetDescendants()) do
		if part:IsA("BasePart") then
			originalCollide[part] = part.CanCollide
		end
	end
	if noclipEnabled then applyNoclip() end
end)

local dragging = false
local dragStart, startPos
local moved = false
local dragThreshold = 5

Button.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		dragging = true
		moved = false
		dragStart = input.Position
		startPos = Button.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then
				dragging = false
				if not moved then
					setNoclip(not noclipEnabled)
				end
			end
		end)
	end
end)

UserInputService.InputChanged:Connect(function(input)
	if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
		local delta = input.Position - dragStart
		if math.abs(delta.X) > dragThreshold or math.abs(delta.Y) > dragThreshold then
			moved = true
		end
		if moved then
			local newX = startPos.X.Offset + delta.X
			local newY = startPos.Y.Offset + delta.Y
			local screenSize = workspace.CurrentCamera.ViewportSize
			local buttonSize = Button.AbsoluteSize
			newX = math.clamp(newX, 0, screenSize.X - buttonSize.X)
			newY = math.clamp(newY, 0, screenSize.Y - buttonSize.Y)
			Button.Position = UDim2.new(
				startPos.X.Scale,
				newX,
				startPos.Y.Scale,
				newY
			)
		end
	end
end)

end


