local function findPromptRecursive(obj) return obj:FindFirstChildWhichIsA("ProximityPrompt", true) end
local function firePrompt(prompt) if prompt and fireproximityprompt then fireproximityprompt(prompt) end end

local activeRadioRoomProcesses = {} 
local function processRadioRoom(room)
    if activeRadioRoomProcesses[room] then return end
    local isRoomActive = true
    activeRadioRoomProcesses[room] = isRoomActive
    task.spawn(function()
        local radios = room.PuzzleObjects.Radios:GetChildren()
        local workEvent = room:WaitForChild("PuzzleWork")
        while room.Parent and isRoomActive do
            local completedRadios = 0
            for _, radio in ipairs(radios) do
                local target, volume = radio:WaitForChild("Target"), radio:WaitForChild("Volume")
                local prompt = radio.base and radio.base.Attachment and findPromptRecursive(radio.base.Attachment)
                if not prompt or not prompt.Parent then completedRadios = completedRadios + 1 continue end
                if volume.Value < 0.9 then target.Value = math.min(target.Value + 0.04, 1) elseif volume.Value > 1 then target.Value = math.max(target.Value - 0.02, 0) end
                workEvent:FireServer(radio, target.Value)
            end
            if completedRadios == #radios then isRoomActive = false break end
            task.wait(0.2)
        end
        activeRadioRoomProcesses[room] = nil 
    end)
end

local function processStrongboxRoom(room)
    local papers, pw = room.PuzzleObjects:FindFirstChild("HintPapers"), room:FindFirstChild("PuzzleWork")
    if papers and pw then
        local code = ""
        for _, obj in ipairs(papers:GetDescendants()) do if obj:IsA("TextLabel") then code = code .. obj.Text end end
        if code ~= "" then pw:FireServer(code) return true end
    end
    return false
end

local function processSweepingRoom(room)
    local objs = room:WaitForChild("PuzzleObjects")
    local buttonLocations, sheet = objs:WaitForChild("ButtonLocations"), objs:WaitForChild("Sheet").SurfaceGui.Frame
    local Camera, entries = Workspace.CurrentCamera, {}
    local function handleButton(prompt)
        local hrp = getHRP() if not hrp then return end
        local parent = prompt.Parent
        local pos = parent:IsA("BasePart") and parent.Position or (findAnyPart(parent) and findAnyPart(parent).Position) or (Camera.CFrame.Position + Camera.CFrame.LookVector * 5)
        hrp.CFrame = CFrame.new(pos + Vector3.new(0, 3, 0))
        Camera.CFrame = CFrame.new(Camera.CFrame.Position, pos)
        task.wait(0.15) firePrompt(prompt)
    end
    for i = 1, 16 do
        local labelObj, buttonObj = sheet:FindFirstChild(string.format("%03d", i)), buttonLocations:FindFirstChild(tostring(i))
        if labelObj and buttonObj then
            local label = labelObj:FindFirstChild("Label")
            local prompt = findPromptRecursive(buttonObj)
            if label and prompt then
                local num = tonumber(string.match(label.Text, "<font.-%>(%d+)%</font%>"))
                if num then table.insert(entries, {order = num, prompt = prompt}) end
            end
        end
    end
    for _, e in ipairs(entries) do if e.order == 4 then handleButton(e.prompt) task.wait(0.2) end end
    table.sort(entries, function(a,b) return a.order < b.order end)
    for _, e in ipairs(entries) do handleButton(e.prompt) task.wait(0.15) end
    return true
end

