        local collisionFolder = currentRoom:FindFirstChild("LocationCollision")
        local mainPart = collisionFolder and collisionFolder:FindFirstChild("LocationCollisionMainPart")
        if mainPart then
            firetouchinterest(hrp, mainPart, 0)
            task.wait(0.02)
            firetouchinterest(hrp, mainPart, 1)
        end
    end
end

local function scanAllDiamonds()
    if not State.diamondFarmEnabled then return end
    local container = getItemContainer()
    if not container then return end
    for _, item in ipairs(container:GetChildren()) do
        processDiamondItem(item)
        if not State.diamondFarmEnabled then break end
    end
end

-- --- 修正した setupPrompt ---
local function setupPrompt(v)
    if v:IsA("ProximityPrompt") then
        -- School.Itemの中にあるかチェック
        local itemContainer = getItemContainer()
        if itemContainer and v:IsDescendantOf(itemContainer) then
            if State.autoModify then
                v.MaxActivationDistance = 9e9
                v.HoldDuration = 0
                v.RequiresLineOfSight = false
                if not v:GetAttribute("Connected") then
                    v:SetAttribute("Connected", true)
                    v.Triggered:Connect(function(p)
                        if p == player and State.autoModify and not State.teleports[v] then
                            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                            if root and v.Parent:IsA("BasePart") then
                                State.teleports[v] = true
                                root.CFrame = v.Parent.CFrame
                                task.wait(0.2)
                                fireproximityprompt(v)
                                task.delay(3, function() State.teleports[v] = nil end)
                            end
                        end
                    end)
                end
            else
                v.MaxActivationDistance = 10
                v:SetAttribute("Connected", nil)
            end
        end
    end
end

local function connectItemFolder()
    local itemFolder = getItemContainer()
    if not itemFolder then return end
    for _, v in pairs(itemFolder:GetDescendants()) do setupPrompt(v) end
    if not itemFolder:GetAttribute("Watched") then
        itemFolder:SetAttribute("Watched", true)
        itemFolder.ChildAdded:Connect(function(child)
            if State.diamondFarmEnabled then
                task.wait(0.2)
                processDiamondItem(child)
            end
        end)
        itemFolder.DescendantAdded:Connect(function(descendant)
            if State.autoModify then task.wait(0.5) setupPrompt(descendant) end
        end)
    end
end

