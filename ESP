-- ビーム再利用用のキャッシュ
local beamCache = {
    Item = {Beam = nil, Attr0 = nil, Attr1 = nil},
    Aooni = {Beam = nil, Attr0 = nil, Attr1 = nil}
}

-- ビーム生成・取得関数
local function getOrCreateBeam(key, color)
    local data = beamCache[key]
    if not data.Beam or not data.Beam.Parent then
        data.Attr0 = Instance.new("Attachment")
        data.Attr1 = Instance.new("Attachment")
        data.Beam = Instance.new("Beam")
        data.Beam.Width0 = 0.05
        data.Beam.Width1 = 0.05
        data.Beam.FaceCamera = true
        data.Beam.Color = ColorSequence.new(color)
        data.Beam.Attachment0 = data.Attr0
        data.Beam.Attachment1 = data.Attr1
    end
    return data
end

local function extractNumber(text)
    local cleanText = text:gsub("<[^>]->","")
    return cleanText:match("%d+") or ""
end

local function getClosest(folder)
    local char = player.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local hrp = char.HumanoidRootPart
    local closest, minDist = nil, math.huge
    for _, obj in pairs(folder:GetChildren()) do
        if obj:IsA("Model") then
            local part = obj.PrimaryPart or obj:FindFirstChild("HumanoidRootPart")
            if part then
                local dist = (hrp.Position - part.Position).Magnitude
                if dist < minDist then
                    minDist = dist
                    closest = part
                end
            end
        end
    end
    return closest
end

local function createESP(model, name, color)
    if not model or not model:IsA("Model") or not model:IsDescendantOf(Workspace) then return end
    local uniqueID = model:GetDebugId()
    local boxName = "ESP_"..uniqueID
    if espFolder:FindFirstChild(boxName) then return end
    
    local size = model.PrimaryPart and model.PrimaryPart.Size or model:GetExtentsSize()
    local box = Instance.new("BoxHandleAdornment")
    box.Name = boxName
    box.Adornee = model.PrimaryPart or model:FindFirstChild("HumanoidRootPart") or model
    box.AlwaysOnTop = true
    box.ZIndex = 0
    box.Size = size
    box.Color3 = color
    box.Transparency = 0.5
    box.Parent = espFolder

    local label = Instance.new("BillboardGui")
    label.Name = "Label_"..boxName
    label.Adornee = box.Adornee
    label.Size = UDim2.new(0,60,0,14)
    label.StudsOffset = Vector3.new(0,3,0)
    label.AlwaysOnTop = true
    label.Parent = espFolder

    local textLabel = Instance.new("TextLabel")
    textLabel.Size = UDim2.new(1,0,1,0)
    textLabel.BackgroundTransparency = 1
    textLabel.TextColor3 = color
    textLabel.TextStrokeTransparency = 0
    textLabel.TextScaled = true
    textLabel.Font = Enum.Font.ArialBold
    textLabel.Text = name
    textLabel.Parent = label

    if ESPConfig.StrongboxNum and model.Name=="StrongboxRoom" then
        local puzzleObjects = model:FindFirstChild("PuzzleObjects")
        local hintFolder = puzzleObjects and puzzleObjects:FindFirstChild("HintPapers")
        local safeModel = puzzleObjects and puzzleObjects:FindFirstChild("Safe")
        if hintFolder and safeModel then
            for _, hint in pairs(hintFolder:GetChildren()) do
                local hintLabel = hint:FindFirstChild("SurfaceGui") and hint.SurfaceGui:FindFirstChild("TextLabel")
                if hintLabel then
                    local adorneePart = safeModel.PrimaryPart or safeModel:FindFirstChildWhichIsA("BasePart") or safeModel
                    local safeGui = Instance.new("BillboardGui")
                    safeGui.Name = "StrongboxRoomLabel_"..model:GetDebugId().."_"..hint:GetDebugId()
                    safeGui.Adornee = adorneePart
                    safeGui.Size = UDim2.new(0,60,0,14)
                    safeGui.StudsOffset = Vector3.new(0,5,0)
                    safeGui.AlwaysOnTop = true
                    safeGui.Parent = espFolder
                    local safeText = Instance.new("TextLabel")
                    safeText.Size = UDim2.new(1,0,1,0)
                    safeText.BackgroundTransparency = 1
                    safeText.TextColor3 = Color3.fromRGB(255,255,0)
                    safeText.TextScaled = true
                    safeText.Font = Enum.Font.ArialBold
                    safeText.Text = extractNumber(hintLabel.Text)
                    safeText.Parent = safeGui
                    table.insert(sweepingLabels,{label=safeText,source=hintLabel,parentGui=safeGui})
                end
            end
        end
    end

    if ESPConfig.SweepingNum and model.Name=="SweepingRoom" then
        local puzzleObjects = model:FindFirstChild("PuzzleObjects")
        local sheet = puzzleObjects and puzzleObjects:FindFirstChild("Sheet")
        local buttons = puzzleObjects and puzzleObjects:FindFirstChild("ButtonLocations")
        if sheet and sheet:FindFirstChild("SurfaceGui") and buttons then
            local frame = sheet.SurfaceGui:FindFirstChild("Frame")
            if frame then
                for i=1,16 do
                    local frameName = string.format("%03d",i)
                    local labelObj = frame:FindFirstChild(frameName) and frame[frameName]:FindFirstChild("Label")
                    local buttonModel = buttons:FindFirstChild(tostring(i))
                    if labelObj and buttonModel then
                        local number = extractNumber(labelObj.Text)
                        if number~="" then
                            local espGui = Instance.new("BillboardGui")
                            espGui.Name = "SweepingRoomLabel_"..model:GetDebugId().."_"..i
                            espGui.Size = UDim2.new(0,50,0,20)
                            espGui.Adornee = buttonModel.PrimaryPart or buttonModel:FindFirstChild("HumanoidRootPart") or buttonModel
                            espGui.AlwaysOnTop = true
                            espGui.Parent = espFolder
                            local numLabel = Instance.new("TextLabel")
                            numLabel.Size = UDim2.new(1,0,1,0)
                            numLabel.BackgroundTransparency = 1
                            numLabel.TextColor3 = Color3.fromRGB(255,255,0)
                            numLabel.TextScaled = true
                            numLabel.Font = Enum.Font.ArialBold
                            numLabel.Text = number
                            numLabel.Parent = espGui -- 修正箇所
                            table.insert(sweepingLabels,{label=numLabel,source=labelObj,parentGui=espGui})
                        end
                    end
                end
            end
        end
    end

    model.AncestryChanged:Connect(function(_,parent)
        if not parent then
            box:Destroy()
            label:Destroy()
        end
    end)
end

local espActive = true
local lastScan = 0
local function scanESP()
    if not espActive then return end
    if tick()-lastScan<5 then return end
    lastScan = tick()

    if ESPConfig.Players then
        for _,plr in pairs(Players:GetPlayers()) do
            if plr~=player and plr.Character then
                if plr:GetAttribute("isAooni") == true then
                    createESP(plr.Character, plr.Name .. " (Aooni)", Color3.new(1,0,0))
                else
                    createESP(plr.Character, plr.Name, Color3.new(1,1,1))
                end
            end
        end
    end

    if ESPConfig.Aooni then
        local aooniFolder = Workspace:FindFirstChild("Aooni")
        if aooniFolder then
            for _,model in pairs(aooniFolder:GetChildren()) do
                if model:IsA("Model") and model.Name=="Aooni" then createESP(model,"Aooni",Color3.new(1,0,0)) end
            end
        end
        if player:GetAttribute("isAooni") == true and player.Character then
            createESP(player.Character, "You (Aooni)", Color3.new(1,0,0))
        end
    end

    if ESPConfig.Items then
        local school = Workspace:FindFirstChild("School")
        local itemFolder = school and school:FindFirstChild("Item")
        if itemFolder then
            for _,item in pairs(itemFolder:GetChildren()) do
                if item:IsA("Model") then
                    createESP(item, item.Name, Color3.fromRGB(0,170,255))
                end
            end
        end
    end

    if ESPConfig.PuzzleRooms and Workspace:FindFirstChild("School") then
        local school=Workspace.School
        for _,room in pairs(school:GetChildren()) do
            if room:IsA("Model") and (room.Name=="SweepingRoom" or room.Name=="StrongboxRoom" or room.Name=="RadioRoom") then createESP(room,room.Name,Color3.fromRGB(255,170,0)) end
        end
    end

    if ESPConfig.Rooms then
        local objValues = ReplicatedStorage:FindFirstChild("ObjectValues")
        local safeAreaValue = objValues and objValues:FindFirstChild("SafeArea")
        
        if safeAreaValue and safeAreaValue:IsA("ObjectValue") and safeAreaValue.Value then
            local targetModel = safeAreaValue.Value
            local displayName = safeAreaValue.Name
            
            if string.find(displayName, "１時間目") then displayName = "1時間目"
            elseif displayName == "ClassRoomLibrary" then displayName = "Library"
            elseif displayName == "ClassRoomScience" then displayName = "Science" end
            
            createESP(targetModel, displayName, Color3.fromRGB(0,255,0))
        end
    end
end

if ESPConfig.Fullbright then
    local function applyFullbright()
        Lighting.Brightness=2
        Lighting.ClockTime=0
        Lighting.FogEnd=100000
        Lighting.GlobalShadows=false
        Lighting.Ambient=Color3.fromRGB(255,255,255)
    end
    applyFullbright()
    for _,prop in pairs({"Brightness","ClockTime","FogEnd","GlobalShadows","Ambient"}) do
        Lighting:GetPropertyChangedSignal(prop):Connect(applyFullbright)
    end
end

RunService.RenderStepped:Connect(function()
    for i=#sweepingLabels,1,-1 do
        local data = sweepingLabels[i]
        if not data.source or not data.source.Parent or not data.parentGui.Parent then
            if data.parentGui then data.parentGui:Destroy() end
            table.remove(sweepingLabels,i)
        else
            local num = extractNumber(data.source.Text)
            if data.label.Text~=num then data.label.Text=num end
        end
    end
    
    local char = player.Character
    local hrp = char and char:FindFirstChild("HumanoidRootPart")
    
    local function updateBeam(key, target, color)
        local data = getOrCreateBeam(key, color)
        if hrp and target and target:IsDescendantOf(Workspace) and ESPConfig.Lines then
            if data.Attr0.Parent ~= hrp then data.Attr0.Parent = hrp end
            if data.Attr1.Parent ~= target then data.Attr1.Parent = target end
            if data.Beam.Parent ~= lineFolder then data.Beam.Parent = lineFolder end
        else
            data.Beam.Parent = nil
            data.Attr0.Parent = nil
            data.Attr1.Parent = nil
        end
    end

    if ESPConfig.Items then
        local school = Workspace:FindFirstChild("School")
        local itemFolder = school and school:FindFirstChild("Item")
        updateBeam("Item", itemFolder and getClosest(itemFolder), Color3.fromRGB(0,170,255))
    else
        updateBeam("Item", nil)
    end

    if ESPConfig.Aooni then
        local aooniFolder = Workspace:FindFirstChild("Aooni")
        updateBeam("Aooni", aooniFolder and getClosest(aooniFolder), Color3.new(1,0,0))
    else
        updateBeam("Aooni", nil)
    end
end)

task.spawn(function()
    while espActive do
        scanESP()
        task.wait(5)
    end
end)
end




