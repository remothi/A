-- --- [Pathfinding 自動歩行処理 (固定機能付き)] ---
local targetPlaceIds = { [95436277090085] = true, [107066417917236] = true, [79254735988889] = true }

if targetPlaceIds[game.PlaceId] then
    local triggered = false
    local lockOn = false

    local function walkToTarget(targetPart)
        local char = player.Character
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not humanoid or not hrp then return end

        local path = PathfindingService:CreatePath({AgentRadius = 2.5, AgentHeight = 5, AgentCanJump = true})
        path:ComputeAsync(hrp.Position, targetPart.Position)
        
        if path.Status == Enum.PathStatus.Success then
            for _, wp in ipairs(path:GetWaypoints()) do
                if isBlacklistPresent() then return end
                if wp.Action == Enum.PathWaypointAction.Jump then humanoid.Jump = true end
                humanoid:MoveTo(wp.Position)
                local completed = false
                local con = humanoid.MoveToFinished:Connect(function() completed = true end)
                local start = tick()
                while not completed and (hrp.Position - wp.Position).Magnitude > 3 and tick() - start < 1.5 do task.wait(0.05) end
                con:Disconnect()
            end
        else
            humanoid:MoveTo(targetPart.Position)
        end
    end

    task.spawn(function()
        while true do
            task.wait(0.5)
            if triggered then break end
            
            -- ロックオン検知
            if not lockOn then
                local room = workspace:FindFirstChild("RoomGUI")
                local slot = room and room:FindFirstChild("SlotCount", true)
                if slot and string.find(tostring(slot.Text), "0/6") then lockOn = true end
            end

            if lockOn then
                local targetPart = nil
                for _, v in pairs(workspace:GetDescendants()) do
                    if v.Name == "LocationCollisionPart" then
                        local gv = v:FindFirstChild("GUIValue")
                        if gv and tostring(gv.Value) == "ClassRoom02" then targetPart = v break end
                    end
                end

                if targetPart then
                    triggered = true
                    -- AnchorしてTouchInterest
                    local hrp = player.Character:FindFirstChild("HumanoidRootPart")
                    if hrp then
                        hrp.Anchored = true
                        firetouchinterest(hrp, targetPart, 0)
                        task.wait(0.2)
                        firetouchinterest(hrp, targetPart, 1)
                        hrp.Anchored = false
                    end
                    walkToTarget(targetPart)
                end
            end
        end
    end)
end
