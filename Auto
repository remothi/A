-- --- [Pathfinding 自動歩行処理 (ラグ対策・先行発火版)] ---
local targetPlaceIds = { [95436277090085] = true, [107066417917236] = true, [79254735988889] = true }

if targetPlaceIds[game.PlaceId] then
    print("[DEBUG] System Active (Auto-Walk Mode)")
    local triggered = false
    local lockOn = false

    local function visualizeWaypoints(waypoints)
        local folder = workspace:FindFirstChild("PathVisualizer") or Instance.new("Folder", workspace)
        folder.Name = "PathVisualizer"
        folder:ClearAllChildren()
        for _, wp in ipairs(waypoints) do
            local p = Instance.new("Part", folder)
            p.Size = Vector3.new(0.6, 0.6, 0.6)
            p.Position = wp.Position
            p.Anchored = true
            p.CanCollide = false
            p.Material = Enum.Material.Neon
            p.Color = Color3.fromRGB(255, 0, 0)
        end
    end

    local function walkToTarget(targetPart)
        local char = player.Character
        local humanoid = char and char:FindFirstChildOfClass("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        if not humanoid or not hrp then return end

        -- 負荷軽減：AgentRadiusを調整した単発計算
        local path = PathfindingService:CreatePath({
            AgentRadius = 2.5,
            AgentHeight = 5,
            AgentCanJump = true
        })
        
        path:ComputeAsync(hrp.Position, targetPart.Position)
        
        if path.Status == Enum.PathStatus.Success then
            local waypoints = path:GetWaypoints()
            visualizeWaypoints(waypoints)

            for i = 2, #waypoints do
                if isBlacklistPresent() then 
                    humanoid:Move(Vector3.new(0,0,0))
                    return 
                end
                
                local wp = waypoints[i]
                if wp.Action == Enum.PathWaypointAction.Jump then
                    humanoid.Jump = true
                end
                
                humanoid:MoveTo(wp.Position)
                
                local completed = false
                local connection
                connection = humanoid.MoveToFinished:Connect(function()
                    completed = true
                end)
                
                local startTime = tick()
                while not completed do
                    if (hrp.Position - wp.Position).Magnitude < 2.5 then break end
                    if tick() - startTime > 1.5 then -- ラグ防止にタイムアウトを少し短縮
                        break 
                    end
                    task.wait(0.05) -- 高速同期
                end
                if connection then connection:Disconnect() end
            end
        else
            warn("[SYSTEM] パス計算失敗。直線的に向かいます。")
            humanoid:MoveTo(targetPart.Position)
        end
    end

    -- ループ監視
    task.spawn(function()
        while true do
            task.wait(0.5)
            
            if triggered then break end

            if isBlacklistPresent() then
                local char = player.Character
                local humanoid = char and char:FindFirstChildOfClass("Humanoid")
                if humanoid then humanoid:Move(Vector3.new(0,0,0)) end
                continue
            end

            if not lockOn then
                local room = workspace:FindFirstChild("RoomGUI")
                if room then
                    local room02 = room:FindFirstChild("ClassRoom02", true)
                    if room02 then
                        local slot = room02:FindFirstChild("SlotCount", true)
                        if slot and string.find(tostring(slot.Text), "0/6") then
                            lockOn = true
                            print("[LOCKON] 0/6を検知。")
                        end
                    end
                end
            end

            if lockOn then
                local targetPart = nil
                local locFolder = workspace:FindFirstChild("Location")
                if locFolder then
                    for _, v in pairs(locFolder:GetDescendants()) do
                        if v.Name == "LocationCollisionPart" then
                            local gv = v:FindFirstChild("GUIValue")
                            if gv and tostring(gv.Value) == "ClassRoom02" then
                                targetPart = v
                                break
                            end
                        end
                    end
                end

                if targetPart then
                    triggered = true
                    
                    -- 【仕様変更】歩き始める前に最優先でTouchInterestを発火（先行判定）
                    local ti = targetPart:FindFirstChildOfClass("TouchTransmitter")
                    if ti then
                        print("[SYSTEM] 歩行開始前にTouchInterestを先行発火します。")
                        firetouchinterest(player.Character:FindFirstChild("HumanoidRootPart"), targetPart, 0)
                        task.wait(0.05)
                        firetouchinterest(player.Character:FindFirstChild("HumanoidRootPart"), targetPart, 1)
                    end
                    
                    -- その後、キャラクターを目的地まで実際に歩かせる
                    walkToTarget(targetPart)
                end
            end
        end
    end)
end

