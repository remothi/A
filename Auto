end

local function loadConfig()
    if isfile and isfile(configFileName) then
        local res = readfile(configFileName)
        if res and res ~= "" then currentMode = res end
    end
    if isfile and isfile(blacklistFileName) then
        local res = readfile(blacklistFileName)
        if res and res ~= "" then
            pcall(function() blacklist = HttpService:JSONDecode(res) end)
        end
    end
end
